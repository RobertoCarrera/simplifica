{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../../dist/supabase-functions",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "ignoreDeprecations": "5.0",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "include": [
    "./**/*.ts",
    "./**/*.js"
  ],
  "exclude": [
    "node_modules",
    "../../node_modules",
    "./dist"
  ]
}