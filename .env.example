# Ejemplo de variables de entorno
# Copia este archivo a .env y personaliza los valores

SUPABASE_URL=
SUPABASE_ANON_KEY=
NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# Rate Limiting — Upstash Redis
# Requerido por: supabase/functions/_shared/rate-limiter.ts
# Obtener en: https://console.upstash.com/
# Nota: se soportan ambas naming conventions (estándar y Upstash REST API).
# Producción usa UPSTASH_REDIS_REST_URL/UPSTASH_REDIS_REST_TOKEN (supabase secrets set).
# ──────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
# Alternativa (naming de Upstash REST API):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# JWT Hook Secret Validation
# Requerido por: supabase/functions/_shared/jwt-hook-validator.ts
# El secreto real se almacena en Supabase Vault: jwt_hook_secret_v1
# Cambiar a false solo en entornos de desarrollo local (sin Vault disponible)
# ──────────────────────────────────────────────────────────────────────────────
JWT_HOOK_SECRET_ENABLED=true
