{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["node", "jest"],
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitAny": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": true
  },
  "include": [
    "src/app/shared/utils/**/*.ts",
    "src/app/shared/*.ts",
    "src/__mocks__/**/*.ts"
  ]
}
